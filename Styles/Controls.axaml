<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia">

    <!--
        Luna control style classes. Every control that a view references through
        Classes="…" is declared here so that views only worry about structure,
        not painting.

        All colors must come from {DynamicResource Luna*} (defined in Theme.axaml).
        Do not inline hex codes here — if a new color is needed, add a token first.
    -->

    <!-- ==================== TextBlock (default foreground) ==================== -->
    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource LunaTextPrimary}"/>
    </Style>

    <Style Selector="TextBlock.label">
        <Setter Property="FontSize" Value="{DynamicResource LunaFontSizeSm}"/>
        <Setter Property="Foreground" Value="{DynamicResource LunaTextSecondary}"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <!-- ==================== Inputs ==================== -->
    <Style Selector="TextBox">
        <Setter Property="Background" Value="{DynamicResource LunaBgTertiary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource LunaBorder}"/>
        <Setter Property="Foreground" Value="{DynamicResource LunaTextPrimary}"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="CornerRadius" Value="{DynamicResource LunaRadiusMd}"/>
    </Style>
    <Style Selector="TextBox:focus">
        <Setter Property="BorderBrush" Value="{DynamicResource LunaAccent}"/>
    </Style>

    <Style Selector="NumericUpDown">
        <Setter Property="Background" Value="{DynamicResource LunaBgTertiary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource LunaBorder}"/>
        <Setter Property="Foreground" Value="{DynamicResource LunaTextPrimary}"/>
    </Style>

    <Style Selector="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource LunaTextPrimary}"/>
    </Style>

    <!-- ==================== Buttons ==================== -->

    <!-- Primary action (green) -->
    <Style Selector="Button.primary">
        <Setter Property="Background" Value="{DynamicResource LunaPrimary}"/>
        <Setter Property="Foreground" Value="{DynamicResource LunaTextOnPrimary}"/>
        <Setter Property="Padding" Value="24,12"/>
        <Setter Property="CornerRadius" Value="{DynamicResource LunaRadiusMd}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="{DynamicResource LunaFontSizeMd}"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <!-- Keyboard focus ring (a11y): visible outline when focused by Tab / keyboard -->
    <Style Selector="Button.primary:focus-visible /template/ ContentPresenter">
        <Setter Property="BorderBrush" Value="{DynamicResource LunaAccent}"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource LunaPrimaryHover}"/>
    </Style>
    <Style Selector="Button.primary:disabled /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource LunaBgTertiary}"/>
        <Setter Property="Foreground" Value="{DynamicResource LunaTextMuted}"/>
    </Style>

    <!-- Secondary action (neutral) -->
    <Style Selector="Button.secondary">
        <Setter Property="Background" Value="{DynamicResource LunaBgTertiary}"/>
        <Setter Property="Foreground" Value="{DynamicResource LunaTextPrimary}"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="CornerRadius" Value="{DynamicResource LunaRadiusMd}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource LunaBorder}"/>
        <Setter Property="BorderThickness" Value="{DynamicResource LunaBorderThin}"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.secondary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource LunaBorder}"/>
    </Style>
    <Style Selector="Button.secondary:focus-visible /template/ ContentPresenter">
        <Setter Property="BorderBrush" Value="{DynamicResource LunaAccent}"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <!-- Update banner button (white with brand-blue text) -->
    <Style Selector="Button.updateBtn">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="CornerRadius" Value="{DynamicResource LunaRadiusSm}"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.updateBtn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#dbeafe"/>
    </Style>
    <Style Selector="Button.updateBtn TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource LunaAccentSubtle}"/>
    </Style>
    <Style Selector="Button.updateBtn:pointerover TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource LunaAccentSubtle}"/>
    </Style>

    <!-- ==================== Surfaces ==================== -->

    <!-- Drop target (empty / pending confirmation state) -->
    <Style Selector="Border.dropZone">
        <Setter Property="Background" Value="{DynamicResource LunaBgSecondary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource LunaBorder}"/>
        <Setter Property="BorderThickness" Value="{DynamicResource LunaBorderThick}"/>
        <Setter Property="CornerRadius" Value="{DynamicResource LunaRadiusXl}"/>
    </Style>
    <Style Selector="Border.dropZone:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource LunaAccent}"/>
        <Setter Property="Background" Value="{DynamicResource LunaBgPrimary}"/>
    </Style>
    <!-- Applied when something is actively being dragged over the drop zone -->
    <Style Selector="Border.dropZone.dragOver">
        <Setter Property="BorderBrush" Value="{DynamicResource LunaAccent}"/>
        <Setter Property="Background" Value="{DynamicResource LunaBgTertiary}"/>
    </Style>

    <!-- Generic elevated card (sidebar summary, dialog sections) -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{DynamicResource LunaBgSecondary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource LunaBorder}"/>
        <Setter Property="BorderThickness" Value="{DynamicResource LunaBorderThin}"/>
        <Setter Property="CornerRadius" Value="{DynamicResource LunaRadiusLg}"/>
    </Style>

    <!-- Settings section card -->
    <Style Selector="Border.section">
        <Setter Property="Background" Value="{DynamicResource LunaBgSecondary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource LunaBorder}"/>
        <Setter Property="BorderThickness" Value="{DynamicResource LunaBorderThin}"/>
        <Setter Property="CornerRadius" Value="{DynamicResource LunaRadiusLg}"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>

    <!-- Reel list item -->
    <Style Selector="Border.reelItem">
        <Setter Property="Background" Value="{DynamicResource LunaBgTertiary}"/>
        <Setter Property="CornerRadius" Value="{DynamicResource LunaRadiusMd}"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- Individual clip row -->
    <Style Selector="Border.clipItem">
        <Setter Property="Background" Value="{DynamicResource LunaBgSecondary}"/>
        <Setter Property="CornerRadius" Value="{DynamicResource LunaRadiusSm}"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Margin" Value="0,4"/>
    </Style>

    <!-- ==================== Animations ==================== -->

    <!-- Opacity pulse — apply to a MaterialIcon with Classes="pulse" to signal
         an in-flight long operation ("still alive, not hung"). -->
    <Style Selector="mi|MaterialIcon.pulse">
        <Style.Animations>
            <Animation Duration="0:0:1.8" IterationCount="INFINITE" Easing="SineEaseInOut">
                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.55"/></KeyFrame>
                <KeyFrame Cue="50%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.55"/></KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Shimmer placeholder — apply to a skeleton Border while its real content loads. -->
    <Style Selector="Border.skeleton">
        <Setter Property="Background" Value="{DynamicResource LunaBgTertiary}"/>
        <Setter Property="CornerRadius" Value="{DynamicResource LunaRadiusSm}"/>
        <Style.Animations>
            <Animation Duration="0:0:1.4" IterationCount="INFINITE" Easing="SineEaseInOut">
                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.55"/></KeyFrame>
                <KeyFrame Cue="50%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.55"/></KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Thumbnail fade-in on first render -->
    <Style Selector="Image.thumb">
        <Style.Animations>
            <Animation Duration="0:0:0.25">
                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.0"/></KeyFrame>
                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- ==================== Cross-fade overlays ====================
         Apply to a Border.overlay with Classes.active bound to a bool. The
         overlay is always in the tree; opacity + hit-testing drive visibility.
         This gives us a smooth fade in/out instead of IsVisible's hard snap. -->
    <Style Selector="Border.overlay">
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="IsHitTestVisible" Value="False"/>
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.22" Easing="CubicEaseOut"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.overlay.active">
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="IsHitTestVisible" Value="True"/>
    </Style>

    <!-- Generic fade-on-visibility wrapper for small callouts (toast, banners).
         Use Classes.visible="{Binding Foo}" to drive the fade. -->
    <Style Selector="Border.fade">
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="IsHitTestVisible" Value="False"/>
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.18" Easing="CubicEaseOut"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.fade.visible">
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="IsHitTestVisible" Value="True"/>
    </Style>

</Styles>
