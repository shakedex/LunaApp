<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LunaApp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="800"
        x:Class="LunaApp.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="Luna Settings"
        Width="600"
        Height="800"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="{DynamicResource LunaBgPrimary}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource LunaBgSecondary}"
                BorderBrush="{DynamicResource LunaBorder}"
                BorderThickness="0,0,0,1" Padding="24,16">
            <TextBlock Text="Settings" FontSize="{DynamicResource LunaFontSizeXl}" FontWeight="Bold"/>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="0" Margin="24">

                <!-- Branding Section -->
                <Border Classes="section">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Report Branding" FontSize="{DynamicResource LunaFontSizeLg}" FontWeight="SemiBold"/>

                        <!-- Logo -->
                        <StackPanel Spacing="8">
                            <TextBlock Classes="label" Text="Company Logo"/>
                            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="*">
                                <!-- Filled preview -->
                                <Border Grid.Column="0"
                                        Width="160" Height="160"
                                        CornerRadius="{DynamicResource LunaRadiusLg}"
                                        Background="{DynamicResource LunaBgTertiary}"
                                        BorderBrush="{DynamicResource LunaBorder}"
                                        BorderThickness="{DynamicResource LunaBorderThin}"
                                        Margin="0,0,16,0"
                                        IsVisible="{Binding HasLogo}">
                                    <Image Source="{Binding LogoBitmap}" Stretch="Uniform" Margin="12"/>
                                </Border>
                                <!-- Empty state placeholder -->
                                <Border Grid.Column="0"
                                        Width="160" Height="160"
                                        CornerRadius="{DynamicResource LunaRadiusLg}"
                                        Background="{DynamicResource LunaBgTertiary}"
                                        BorderBrush="{DynamicResource LunaBorder}"
                                        BorderThickness="{DynamicResource LunaBorderThin}"
                                        Margin="0,0,16,0"
                                        IsVisible="{Binding !HasLogo}">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                                        <mi:MaterialIcon Kind="ImageOutline" Width="48" Height="48" Foreground="{DynamicResource LunaTextMuted}"/>
                                        <TextBlock Text="No logo" FontSize="{DynamicResource LunaFontSizeSm}"
                                                   Foreground="{DynamicResource LunaTextMuted}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding LogoPath, FallbackValue='No logo selected'}"
                                               Foreground="{DynamicResource LunaTextSecondary}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="PNG, JPG, WebP or SVG. Shown at the top of every report."
                                               FontSize="{DynamicResource LunaFontSizeXs}"
                                               Foreground="{DynamicResource LunaTextMuted}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Vertical" Spacing="8" VerticalAlignment="Top">
                                    <Button Classes="secondary" Command="{Binding BrowseLogoCommand}" Content="Browse"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                    <Button Classes="secondary" Command="{Binding ClearLogoCommand}" Content="Clear"
                                            IsVisible="{Binding HasLogo}"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- Project Name -->
                        <StackPanel Spacing="4">
                            <TextBlock Classes="label" Text="Project Name"/>
                            <TextBox Text="{Binding ProjectName}" Watermark="e.g., My Film Production"/>
                        </StackPanel>

                        <!-- Production Company -->
                        <StackPanel Spacing="4">
                            <TextBlock Classes="label" Text="Production Company"/>
                            <TextBox Text="{Binding ProductionCompany}" Watermark="e.g., Acme Films"/>
                        </StackPanel>

                        <!-- Grid for DIT, Director, DP -->
                        <Grid ColumnDefinitions="*,16,*,16,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Classes="label" Text="DIT"/>
                                <TextBox Text="{Binding DitName}" Watermark="Your name"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Classes="label" Text="Director"/>
                                <TextBox Text="{Binding Director}" Watermark="Director name"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4" Spacing="4">
                                <TextBlock Classes="label" Text="DP"/>
                                <TextBox Text="{Binding Dp}" Watermark="DP name"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Output Section -->
                <Border Classes="section">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Output Settings" FontSize="{DynamicResource LunaFontSizeLg}" FontWeight="SemiBold"/>

                        <!-- Output Folder -->
                        <StackPanel Spacing="4">
                            <TextBlock Classes="label" Text="Report Output Folder"/>
                            <Grid ColumnDefinitions="*,8,Auto">
                                <TextBox Grid.Column="0" Text="{Binding OutputFolder}" IsReadOnly="True"/>
                                <Button Grid.Column="2" Classes="secondary" Command="{Binding BrowseOutputFolderCommand}" Content="Browse"/>
                            </Grid>
                        </StackPanel>

                        <!-- Thumbnails per clip -->
                        <StackPanel Spacing="4">
                            <TextBlock Classes="label" Text="Thumbnails per Clip"/>
                            <NumericUpDown Value="{Binding ThumbnailsPerClip}" Minimum="0" Maximum="10" Width="120" HorizontalAlignment="Left"/>
                            <TextBlock Text="Set to 0 to disable thumbnail generation"
                                       FontSize="{DynamicResource LunaFontSizeXs}"
                                       Foreground="{DynamicResource LunaTextMuted}"/>
                        </StackPanel>

                        <!-- Checkboxes -->
                        <StackPanel Spacing="8" Margin="0,8,0,0">
                            <CheckBox Content="Generate HTML reports by default" IsChecked="{Binding GenerateHtmlByDefault}"/>
                            <CheckBox Content="Generate PDF reports by default" IsChecked="{Binding GeneratePdfByDefault}"/>
                            <CheckBox Content="Open report when complete" IsChecked="{Binding OpenReportWhenDone}"
                                      IsEnabled="{Binding WillGenerateAnyReport}"/>
                            <CheckBox Content="Group PDFs in separate folder" IsChecked="{Binding GroupPdfsInSeparateFolder}"
                                      IsEnabled="{Binding GeneratePdfByDefault}"/>
                        </StackPanel>

                        <!-- Report theme -->
                        <StackPanel Spacing="4" Margin="0,12,0,0">
                            <TextBlock Classes="label" Text="Report theme"/>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <RadioButton GroupName="ReportTheme"
                                             IsChecked="{Binding IsLightTheme, Mode=TwoWay}"
                                             Content="Light"/>
                                <RadioButton GroupName="ReportTheme"
                                             IsChecked="{Binding IsDarkTheme, Mode=TwoWay}"
                                             Content="Dark"/>
                            </StackPanel>
                            <TextBlock Text="Applies to both the HTML and PDF output."
                                       FontSize="{DynamicResource LunaFontSizeXs}"
                                       Foreground="{DynamicResource LunaTextMuted}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Camera Support Section -->
                <Border Classes="section">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <mi:MaterialIcon Kind="Camera" Width="20" Height="20" Foreground="{DynamicResource LunaAccent}"/>
                            <TextBlock Text="Camera Support" FontSize="{DynamicResource LunaFontSizeLg}" FontWeight="SemiBold"/>
                        </StackPanel>

                        <TextBlock Text="Which camera families Luna can read on this install. Proprietary formats arrive through future releases; nothing to configure here."
                                   FontSize="{DynamicResource LunaFontSizeXs}"
                                   Foreground="{DynamicResource LunaTextMuted}"
                                   TextWrapping="Wrap"/>

                        <ItemsControl ItemsSource="{Binding CameraSupports}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CameraSupportRow">
                                    <Border BorderBrush="{DynamicResource LunaBorder}"
                                            BorderThickness="0,0,0,1"
                                            Padding="0,10">
                                        <StackPanel Spacing="8">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <StackPanel Grid.Column="0" Spacing="2">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontSize="{DynamicResource LunaFontSizeMd}"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Summary}"
                                                               FontSize="{DynamicResource LunaFontSizeXs}"
                                                               Foreground="{DynamicResource LunaTextMuted}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <Border Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Padding="10,4"
                                                        CornerRadius="{DynamicResource LunaRadiusSm}"
                                                        Background="{DynamicResource LunaBgTertiary}">
                                                    <TextBlock Text="{Binding State}"
                                                               FontSize="{DynamicResource LunaFontSizeXs}"
                                                               Foreground="{DynamicResource LunaTextSecondary}"/>
                                                </Border>
                                            </Grid>

                                            <!-- Install action — only on rows that have an installer wired and aren't already Ready. -->
                                            <Button Classes="secondary"
                                                    Content="{Binding InstallButtonLabel}"
                                                    Command="{Binding InstallCommand}"
                                                    IsEnabled="{Binding CanInstall}"
                                                    IsVisible="{Binding ShowInstallButton}"
                                                    HorizontalAlignment="Left"/>

                                            <!-- In-flight progress -->
                                            <StackPanel Spacing="4" IsVisible="{Binding IsInstalling}">
                                                <ProgressBar Value="{Binding InstallProgress}" Minimum="0" Maximum="1"/>
                                                <TextBlock FontSize="{DynamicResource LunaFontSizeXs}"
                                                           Foreground="{DynamicResource LunaTextMuted}"
                                                           Text="{Binding InstallProgress, StringFormat='Downloading… {0:P0}'}"/>
                                            </StackPanel>

                                            <!-- Awaiting-detect state — installer is running outside Luna; user clicks Detect when done. -->
                                            <StackPanel Spacing="6" IsVisible="{Binding ShowDetectButton}">
                                                <TextBlock FontSize="{DynamicResource LunaFontSizeXs}"
                                                           Foreground="{DynamicResource LunaTextSecondary}"
                                                           TextWrapping="Wrap"
                                                           Text="The vendor installer is now open. Complete it (accept the EULA, click through to Finish), then click Detect below."/>
                                                <Button Classes="secondary"
                                                        Content="Detect"
                                                        Command="{Binding DetectCommand}"
                                                        HorizontalAlignment="Left"/>
                                            </StackPanel>

                                            <!-- Failure / "still not detected" detail (verbatim) -->
                                            <TextBlock Text="{Binding InstallError}"
                                                       FontSize="{DynamicResource LunaFontSizeXs}"
                                                       Foreground="{DynamicResource LunaWarning}"
                                                       TextWrapping="Wrap"
                                                       IsVisible="{Binding InstallError, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2"
                Background="{DynamicResource LunaBgSecondary}"
                BorderBrush="{DynamicResource LunaBorder}"
                BorderThickness="0,1,0,0" Padding="24,16">
            <Grid ColumnDefinitions="*,Auto,8,Auto">
                <Button Grid.Column="1" Classes="secondary" Click="OnCancel" Content="Cancel"/>
                <Button Grid.Column="3" Classes="primary"
                        Command="{Binding SaveCommand}"
                        Content="Save Settings"/>
            </Grid>
        </Border>
    </Grid>

</Window>
