<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LunaApp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="480"
        x:Class="LunaApp.Views.CreditsWindow"
        x:DataType="vm:CreditsViewModel"
        Title="About Luna"
        Width="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource LunaBgPrimary}">

    <StackPanel Margin="28" Spacing="20">

        <!-- Identity row -->
        <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
            <Image Source="/Assets/luna-logo.webp" Width="44" Height="46"
                   RenderOptions.BitmapInterpolationMode="HighQuality"/>
            <StackPanel VerticalAlignment="Center" Spacing="2">
                <TextBlock Text="Luna" FontSize="{DynamicResource LunaFontSize2Xl}" FontWeight="Bold"/>
                <TextBlock Text="{Binding VersionText}"
                           FontSize="{DynamicResource LunaFontSizeXs}"
                           Foreground="{DynamicResource LunaTextMuted}"/>
            </StackPanel>
        </StackPanel>

        <!-- Credit line -->
        <TextBlock TextWrapping="Wrap"
                   FontSize="{DynamicResource LunaFontSizeSm}"
                   Foreground="{DynamicResource LunaTextSecondary}">
            <Run Text="Designed and built by"/>
            <Run Text="Shaked Lipszyc" FontWeight="SemiBold" Foreground="{DynamicResource LunaTextPrimary}"/>
        </TextBlock>

        <!-- Links — three compact buttons in a row -->
        <UniformGrid Columns="3" Rows="1">
            <Button Classes="secondary" Margin="0,0,4,0"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Command="{Binding OpenLinkCommand}"
                    CommandParameter="https://shaked.co"
                    ToolTip.Tip="shaked.co">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <mi:MaterialIcon Kind="Web" Width="14" Height="14" Foreground="{DynamicResource LunaAccent}"/>
                    <TextBlock Text="Website"/>
                </StackPanel>
            </Button>
            <Button Classes="secondary" Margin="2,0"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Command="{Binding OpenLinkCommand}"
                    CommandParameter="https://github.com/shakedex/LunaApp"
                    ToolTip.Tip="github.com/shakedex/LunaApp">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <mi:MaterialIcon Kind="Github" Width="14" Height="14" Foreground="{DynamicResource LunaAccent}"/>
                    <TextBlock Text="GitHub"/>
                </StackPanel>
            </Button>
            <Button Classes="secondary" Margin="4,0,0,0"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Command="{Binding OpenLinkCommand}"
                    CommandParameter="https://ozer2.one"
                    ToolTip.Tip="ozer2.one">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <mi:MaterialIcon Kind="MovieOpenOutline" Width="14" Height="14" Foreground="{DynamicResource LunaAccent}"/>
                    <TextBlock Text="Ozer²"/>
                </StackPanel>
            </Button>
        </UniformGrid>

        <!-- Update strip — single line -->
        <Border Background="{DynamicResource LunaBgSecondary}"
                BorderBrush="{DynamicResource LunaBorder}"
                BorderThickness="{DynamicResource LunaBorderThin}"
                CornerRadius="{DynamicResource LunaRadiusMd}"
                Padding="14,12">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding UpdateStatusText}"
                           FontSize="{DynamicResource LunaFontSizeSm}"
                           Foreground="{DynamicResource LunaTextSecondary}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <Button Grid.Column="1" Classes="secondary"
                        Padding="10,6"
                        Command="{Binding CheckForUpdatesCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <mi:MaterialIcon Kind="Refresh" Width="13" Height="13"
                                         Foreground="{DynamicResource LunaTextSecondary}"
                                         IsVisible="{Binding !IsCheckingForUpdates}"/>
                        <TextBlock Text="{Binding CheckForUpdatesButtonText}"
                                   FontSize="{DynamicResource LunaFontSizeSm}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Disclaimer — plain text, no card -->
        <TextBlock TextWrapping="Wrap"
                   FontSize="{DynamicResource LunaFontSizeXs}"
                   Foreground="{DynamicResource LunaTextMuted}"
                   Text="Luna is provided “as is”, without warranty of any kind. The author is not liable for data loss or damage arising from use of this software — always verify reports against the source media. Not affiliated with ARRI, Sony, Blackmagic, RED, or any other manufacturer; trademarks belong to their owners. Built on FFmpeg (LGPL), Avalonia, QuestPDF, MediaInfo, and Velopack."/>

    </StackPanel>

</Window>
