<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LunaApp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:LunaApp.Models"
        xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="LunaApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="RootWindow"
        Icon="/Assets/luna-logo.ico"
        Title="Luna"
        MinWidth="900"
        MinHeight="600"
        Background="{DynamicResource LunaBgPrimary}">

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource LunaBgSecondary}"
                BorderBrush="{DynamicResource LunaBorder}"
                BorderThickness="0,0,0,1"
                Padding="24,16">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Logo and title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Image Source="/Assets/luna-logo.webp" Width="36" Height="38" RenderOptions.BitmapInterpolationMode="HighQuality"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Luna" FontSize="{DynamicResource LunaFontSizeXl}" FontWeight="Bold"/>
                        <TextBlock Text="Camera Report Generator" FontSize="{DynamicResource LunaFontSizeXs}" Foreground="{DynamicResource LunaTextSecondary}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Header buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <!-- DEV: Development tools toggle button -->
                    <Button Classes="secondary" Command="{Binding ToggleLogViewerCommand}" VerticalAlignment="Center"
                            ToolTip.Tip="Toggle Developer Tools"
                            AutomationProperties.Name="Toggle Developer Tools">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="Wrench" Width="16" Height="16" Foreground="{DynamicResource LunaTextSecondary}"/>
                            <TextBlock Text="Dev" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Settings button -->
                    <Button Classes="secondary" Command="{Binding OpenSettingsCommand}" VerticalAlignment="Center"
                            AutomationProperties.Name="Open settings">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="Cog" Width="16" Height="16" Foreground="{DynamicResource LunaTextSecondary}"/>
                            <TextBlock Text="Settings" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- About / Credits button -->
                    <Button Classes="secondary" Command="{Binding OpenCreditsCommand}" VerticalAlignment="Center"
                            ToolTip.Tip="About Luna"
                            AutomationProperties.Name="About Luna">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="InformationOutline" Width="16" Height="16" Foreground="{DynamicResource LunaTextSecondary}"/>
                            <TextBlock Text="About" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Update toast - floats top-right; doesn't take a full row of chrome -->
        <Border Grid.Row="1" Height="0"/>

        <!-- Main content + overlays -->
        <Grid Grid.Row="2" Margin="24">

            <!-- Update toast (top-right floating card) — fades in via .fade class -->
            <Border Classes="fade"
                    Classes.visible="{Binding HasUpdateAvailable}"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Background="{DynamicResource LunaBgSecondary}"
                    BorderBrush="{DynamicResource LunaAccentSubtle}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource LunaRadiusLg}"
                    Padding="16,14" MaxWidth="380"
                    Margin="0,8,8,0"
                    ZIndex="50">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <mi:MaterialIcon Kind="Update" Width="20" Height="20" Foreground="{DynamicResource LunaAccent}"/>
                        <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource LunaTextPrimary}">
                            <Run Text="Luna"/>
                            <Run Text="{Binding UpdateVersion}" FontWeight="Bold"/>
                            <Run Text="is available"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Download progress -->
                    <StackPanel Spacing="4" IsVisible="{Binding IsDownloadingUpdate}">
                        <ProgressBar Value="{Binding UpdateDownloadProgress}" Maximum="100"
                                     Height="4"
                                     Foreground="{DynamicResource LunaAccent}"
                                     Background="{DynamicResource LunaBgTertiary}"
                                     CornerRadius="2"/>
                        <TextBlock Text="{Binding UpdateDownloadProgress, StringFormat='Downloading… {0}%'}"
                                   FontSize="{DynamicResource LunaFontSizeXs}"
                                   Foreground="{DynamicResource LunaTextSecondary}"/>
                    </StackPanel>

                    <!-- Actions -->
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <!-- Download -->
                        <Button Classes="secondary" Padding="12,6"
                                Command="{Binding DownloadUpdateCommand}"
                                IsVisible="{Binding !IsUpdateReady}"
                                IsEnabled="{Binding !IsDownloadingUpdate}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <mi:MaterialIcon Kind="Download" Width="14" Height="14" Foreground="{DynamicResource LunaTextSecondary}"/>
                                <TextBlock Text="Download"/>
                            </StackPanel>
                        </Button>
                        <!-- Restart -->
                        <Button Classes="primary" Padding="12,6"
                                Command="{Binding ApplyUpdateCommand}"
                                IsVisible="{Binding IsUpdateReady}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <mi:MaterialIcon Kind="Restart" Width="14" Height="14" Foreground="White"/>
                                <TextBlock Text="Restart Now"/>
                            </StackPanel>
                        </Button>
                        <!-- Remind me later (3 days) -->
                        <Button Classes="secondary" Padding="12,6"
                                Command="{Binding RemindUpdateLaterCommand}"
                                ToolTip.Tip="Hide this for 3 days">
                            <TextBlock Text="Later"/>
                        </Button>
                        <!-- Dismiss for this session only -->
                        <Button Classes="secondary" Padding="8,6"
                                Command="{Binding DismissUpdateCommand}"
                                ToolTip.Tip="Dismiss"
                                AutomationProperties.Name="Dismiss update notification">
                            <mi:MaterialIcon Kind="Close" Width="12" Height="12" Foreground="{DynamicResource LunaTextSecondary}"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Empty state: Drop zone (only when no folder selected and not processing) -->
            <Border Classes="dropZone"
                    Classes.dragOver="{Binding IsDragOver}"
                    IsVisible="{Binding ShowDropZone}"
                    DragDrop.AllowDrop="True"
                    Cursor="Hand">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                    <!-- Moon icon -->
                    <Border Width="80" Height="80" CornerRadius="40"
                            Background="{DynamicResource LunaBgTertiary}" HorizontalAlignment="Center">
                        <mi:MaterialIcon Kind="MoonWaningCrescent" Width="40" Height="40" Foreground="{DynamicResource LunaAccent}"/>
                    </Border>
                    <TextBlock Text="Drop camera footage here" FontSize="{DynamicResource LunaFontSizeXl}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="or click to browse for a folder" FontSize="{DynamicResource LunaFontSizeMd}" Foreground="{DynamicResource LunaTextSecondary}" HorizontalAlignment="Center"/>
                    <Button Classes="secondary" Command="{Binding BrowseFolderCommand}" HorizontalAlignment="Center" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="FolderOpen" Width="16" Height="16" Foreground="{DynamicResource LunaTextSecondary}"/>
                            <TextBlock Text="Browse Folder" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Pending confirmation state: Folder selected, waiting for user to start processing -->
            <Border Classes="dropZone"
                    IsVisible="{Binding ShowPendingConfirmation}"
                    Background="{DynamicResource LunaBgSecondary}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">
                    <!-- Folder icon with checkmark -->
                    <Border Width="100" Height="100" CornerRadius="50"
                            Background="{DynamicResource LunaBgTertiary}" HorizontalAlignment="Center">
                        <mi:MaterialIcon Kind="FolderOpen" Width="48" Height="48" Foreground="{DynamicResource LunaAccent}"/>
                    </Border>

                    <!-- Folder name and clip count -->
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding PendingFolderName}" FontSize="{DynamicResource LunaFontSize2Xl}" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                            <TextBlock FontSize="{DynamicResource LunaFontSize3Xl}" FontWeight="Bold" Foreground="{DynamicResource LunaAccent}" VerticalAlignment="Center">
                                <TextBlock.Text>
                                    <Binding Path="PendingClipCount"/>
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock Text="video clips found" FontSize="18" Foreground="{DynamicResource LunaTextSecondary}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
                        <Button Classes="secondary" Command="{Binding CancelPendingCommand}" Padding="24,14">
                            <TextBlock Text="Cancel" FontSize="{DynamicResource LunaFontSizeMd}"/>
                        </Button>
                        <Button Classes="primary" Command="{Binding StartProcessingCommand}" Padding="32,14">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <mi:MaterialIcon Kind="CheckCircle" Width="20" Height="20" Foreground="White"/>
                                <TextBlock Text="Create Report" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Hint text -->
                    <TextBlock Text="Clicking 'Create Report' will extract metadata and thumbnails from your footage"
                               FontSize="13" Foreground="{DynamicResource LunaTextMuted}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Content: Reels list -->
            <Grid IsVisible="{Binding HasReels}" ColumnDefinitions="*,320" RowDefinitions="Auto,*">

                <!-- Search bar: text box + filter summary + clear in a single row -->
                <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,16,12" ColumnDefinitions="*,Auto,Auto">
                    <TextBox Grid.Column="0"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Watermark="Search reels or file names…"
                             Padding="12,8"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding FilterSummary}"
                               IsVisible="{Binding IsSearchActive}"
                               FontSize="{DynamicResource LunaFontSizeSm}"
                               Foreground="{DynamicResource LunaTextMuted}"
                               VerticalAlignment="Center"
                               Margin="12,0,4,0"/>
                    <Button Grid.Column="2" Classes="secondary"
                            Command="{Binding ClearSearchCommand}"
                            IsVisible="{Binding IsSearchActive}"
                            Margin="8,0,0,0" Padding="12,8"
                            ToolTip.Tip="Clear search"
                            AutomationProperties.Name="Clear search">
                        <mi:MaterialIcon Kind="Close" Width="14" Height="14" Foreground="{DynamicResource LunaTextSecondary}"/>
                    </Button>
                </Grid>

                <!-- Reels and clips (virtualized — only visible reels realize their clip templates) -->
                <ListBox Grid.Row="1" Grid.Column="0" Margin="0,0,16,0"
                         ItemsSource="{Binding FilteredReels}"
                         SelectionMode="Single"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.Styles>
                        <!-- Remove Fluent's selection highlight so our reelItem styling shows through -->
                        <Style Selector="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:CameraReel">
                                <Border Classes="reelItem" Margin="0,0,0,16">
                                    <StackPanel Spacing="12">
                                        <!-- Reel header -->
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0" Background="{DynamicResource LunaAccent}" CornerRadius="4" Padding="12,6" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayLabel}" FontWeight="Bold" Foreground="{DynamicResource LunaTextOnAccent}"/>
                                            </Border>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                                                <TextBlock Foreground="{DynamicResource LunaTextSecondary}">
                                                    <Run Text="{Binding ClipCount}"/>
                                                    <Run Text="clips"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding TotalDuration, StringFormat='{}{0:hh\\:mm\\:ss}'}" Foreground="{DynamicResource LunaTextSecondary}"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Clips list -->
                                        <ItemsControl ItemsSource="{Binding Clips}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="models:CameraClip">
                                                    <Border Classes="clipItem">
                                                        <Border.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="Reveal in Explorer"
                                                                          Command="{Binding DataContext.RevealClipInExplorerCommand, ElementName=RootWindow}"
                                                                          CommandParameter="{Binding}">
                                                                    <MenuItem.Icon>
                                                                        <mi:MaterialIcon Kind="FolderOpen" Width="14" Height="14"/>
                                                                    </MenuItem.Icon>
                                                                </MenuItem>
                                                                <MenuItem Header="Copy file name"
                                                                          Command="{Binding DataContext.CopyClipFilenameCommand, ElementName=RootWindow}"
                                                                          CommandParameter="{Binding}"/>
                                                                <MenuItem Header="Copy full path"
                                                                          Command="{Binding DataContext.CopyClipPathCommand, ElementName=RootWindow}"
                                                                          CommandParameter="{Binding}"/>
                                                                <MenuItem Header="Copy all metadata"
                                                                          Command="{Binding DataContext.CopyClipMetadataCommand, ElementName=RootWindow}"
                                                                          CommandParameter="{Binding}">
                                                                    <MenuItem.Icon>
                                                                        <mi:MaterialIcon Kind="ContentCopy" Width="14" Height="14"/>
                                                                    </MenuItem.Icon>
                                                                </MenuItem>
                                                            </ContextMenu>
                                                        </Border.ContextMenu>
                                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                                            <!-- Single thumbnail or video icon -->
                                                            <Grid Grid.Column="0" Width="80" Height="45" Margin="0,0,16,0">
                                                                <!-- Actual thumbnail image -->
                                                                <Image Classes="thumb"
                                                                       Source="{Binding FirstThumbnail.Bitmap}"
                                                                       Width="80" Height="45"
                                                                       Stretch="UniformToFill"
                                                                       IsVisible="{Binding HasThumbnail}"/>
                                                                <!-- Fallback: Video icon when no thumbnail -->
                                                                <Border Width="80" Height="45" Background="{DynamicResource LunaBorder}" CornerRadius="2"
                                                                        IsVisible="{Binding !HasThumbnail}">
                                                                    <mi:MaterialIcon Kind="Video" Width="24" Height="24" Foreground="{DynamicResource LunaTextMuted}"/>
                                                                </Border>
                                                            </Grid>

                                                            <!-- Clip info -->
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                                                <TextBlock Text="{Binding FileName}" FontWeight="SemiBold"/>
                                                                <StackPanel Orientation="Horizontal" Spacing="12"
                                                                            IsVisible="{Binding UnsupportedNotice, Converter={x:Static ObjectConverters.IsNull}}">
                                                                    <TextBlock Text="{Binding Resolution}" FontSize="{DynamicResource LunaFontSizeSm}" Foreground="{DynamicResource LunaTextSecondary}"/>
                                                                    <TextBlock Text="{Binding Codec}" FontSize="{DynamicResource LunaFontSizeSm}" Foreground="{DynamicResource LunaTextSecondary}"/>
                                                                    <TextBlock Text="{Binding DurationFormatted}" FontSize="{DynamicResource LunaFontSizeSm}" Foreground="{DynamicResource LunaTextSecondary}"/>
                                                                </StackPanel>
                                                                <!-- Unsupported-format notice: shown only when the file's camera support is not Ready. -->
                                                                <TextBlock Text="{Binding UnsupportedNotice.DisplayName, StringFormat='{}{0} — support not yet available'}"
                                                                           FontSize="{DynamicResource LunaFontSizeSm}"
                                                                           Foreground="{DynamicResource LunaTextSecondary}"
                                                                           IsVisible="{Binding UnsupportedNotice, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                                                <TextBlock Text="{Binding UnsupportedNotice.Reason}"
                                                                           FontSize="{DynamicResource LunaFontSizeXs}"
                                                                           Foreground="{DynamicResource LunaTextMuted}"
                                                                           TextWrapping="Wrap"
                                                                           IsVisible="{Binding UnsupportedNotice, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                                                <!-- Thumbnail-extraction outcome: surfaced when metadata worked but frames didn't
                                                                     (NoDecoder for X-OCN/ARRIRAW/BRAW/REDCODE, SeekFailed for busted MXF indexes, etc.). -->
                                                                <TextBlock Text="{Binding ThumbnailIssueSummary}"
                                                                           FontSize="{DynamicResource LunaFontSizeXs}"
                                                                           Foreground="{DynamicResource LunaTextMuted}"
                                                                           TextWrapping="Wrap"
                                                                           IsVisible="{Binding HasThumbnailIssue}"/>
                                                            </StackPanel>

                                                            <!-- Timecode -->
                                                            <TextBlock Grid.Column="2" Text="{Binding Timecode}"
                                                                       FontFamily="{DynamicResource LunaFontMono}"
                                                                       FontSize="{DynamicResource LunaFontSizeSm}"
                                                                       Foreground="{DynamicResource LunaAccent}" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Sidebar: Summary and actions -->
                <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Classes="card" Padding="20">
                    <StackPanel Spacing="20">
                        <TextBlock Text="Report Summary" FontSize="{DynamicResource LunaFontSizeLg}" FontWeight="SemiBold"/>

                        <!-- Stats — reels are an internal grouping, not a metric the
                             user cares about, so we surface the per-clip totals + a
                             raw file count (clips plus sidecars/metadata the camera
                             wrote alongside, used in the summary only — not in the
                             generated report). -->
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Clips" Foreground="{DynamicResource LunaTextSecondary}"/>
                                <TextBlock Grid.Column="1" Text="{Binding TotalClipCount}" FontWeight="SemiBold"/>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Files" Foreground="{DynamicResource LunaTextSecondary}"/>
                                <TextBlock Grid.Column="1" Text="{Binding TotalFilesCount}" FontWeight="SemiBold"/>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Total Duration" Foreground="{DynamicResource LunaTextSecondary}"/>
                                <TextBlock Grid.Column="1" Text="{Binding TotalDuration, StringFormat='{}{0:hh\\:mm\\:ss}'}" FontWeight="SemiBold"/>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Total Size" Foreground="{DynamicResource LunaTextSecondary}"/>
                                <TextBlock Grid.Column="1" Text="{Binding TotalSizeFormatted}" FontWeight="SemiBold"/>
                            </Grid>
                        </StackPanel>

                        <Border Height="1" Background="{DynamicResource LunaBorder}"/>

                        <!-- Output options -->
                        <StackPanel Spacing="8">
                            <CheckBox Content="HTML Report" IsChecked="{Binding GenerateHtml}"/>
                            <CheckBox Content="PDF Report" IsChecked="{Binding GeneratePdf}"/>
                            <CheckBox Content="Open when complete" IsChecked="{Binding OpenWhenDone}" FontSize="{DynamicResource LunaFontSizeSm}"/>
                        </StackPanel>

                        <Border Height="1" Background="{DynamicResource LunaBorder}"/>

                        <!-- Per-run report label, e.g. "Day 02" / "Studio A" / "B-roll".
                             Auto-filled from the scanned folder name; user can override.
                             Appears in the report header next to the project name and on
                             the output folder, so back-to-back generations are distinguishable. -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Report name"
                                       FontSize="{DynamicResource LunaFontSizeXs}"
                                       Foreground="{DynamicResource LunaTextSecondary}"
                                       FontWeight="SemiBold"/>
                            <TextBox Text="{Binding ReportName, Mode=TwoWay}"
                                     Watermark="e.g., Day 02 — Studio A"/>
                        </StackPanel>

                        <!-- Generate button -->
                        <Button Classes="primary"
                                Command="{Binding GenerateReportsCommand}"
                                IsEnabled="{Binding CanGenerate}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <mi:MaterialIcon Kind="CheckCircle" Width="18" Height="18" Foreground="White"
                                          IsVisible="{Binding !IsProcessing}"/>
                                <TextBlock Text="{Binding GenerateButtonText}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Clear button -->
                        <Button Classes="secondary"
                                Command="{Binding ClearCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                IsVisible="{Binding HasReels}">
                            <TextBlock Text="Clear &amp; Start Over"/>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Processing overlay — fades in/out via the .overlay class -->
            <Border Classes="overlay"
                    Classes.active="{Binding IsProcessing}"
                    Background="{DynamicResource LunaBgOverlay}"
                    CornerRadius="{DynamicResource LunaRadiusXl}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">
                    <!-- Moon icon with pulsing effect -->
                    <Grid Width="120" Height="120" HorizontalAlignment="Center">
                        <Border Width="120" Height="120" CornerRadius="60" BorderBrush="{DynamicResource LunaBgTertiary}" BorderThickness="4"/>
                        <Border Width="80" Height="80" CornerRadius="40" Background="{DynamicResource LunaBgSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <mi:MaterialIcon Classes="pulse" Kind="MoonWaningCrescent" Width="40" Height="40" Foreground="{DynamicResource LunaAccent}"/>
                        </Border>
                    </Grid>

                    <!-- Status text -->
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding PhaseLabel}"
                                   FontSize="{DynamicResource LunaFontSizeXl}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                        <TextBlock Text="{Binding PhaseDetail}"
                                   FontSize="{DynamicResource LunaFontSizeMd}"
                                   Foreground="{DynamicResource LunaTextSecondary}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="500"/>
                        <TextBlock Text="{Binding EtaText}"
                                   FontSize="{DynamicResource LunaFontSizeSm}"
                                   Foreground="{DynamicResource LunaTextMuted}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Progress bar -->
                    <StackPanel Spacing="8" Width="400" HorizontalAlignment="Center">
                        <ProgressBar Value="{Binding Progress}"
                                     Maximum="100"
                                     Height="8"
                                     Foreground="{DynamicResource LunaAccent}"
                                     Background="{DynamicResource LunaBgTertiary}"
                                     CornerRadius="4"/>
                        <TextBlock Text="{Binding Progress, StringFormat='{}{0}%'}"
                                   FontSize="{DynamicResource LunaFontSizeMd}"
                                   Foreground="{DynamicResource LunaTextSecondary}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Cancel button -->
                    <Button Classes="secondary"
                            Command="{Binding CancelProcessingCommand}"
                            IsEnabled="{Binding CanCancel}"
                            HorizontalAlignment="Center"
                            Padding="20,10"
                            Margin="0,8,0,0"
                            AutomationProperties.Name="Cancel current operation">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="Close" Width="16" Height="16" Foreground="{DynamicResource LunaTextSecondary}"/>
                            <TextBlock Text="Cancel" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- DEV: Developer Tools panel -->
        <Border Grid.Row="3"
                Background="{DynamicResource LunaBgPrimary}"
                BorderBrush="{DynamicResource LunaBorder}"
                BorderThickness="0,1,0,0"
                Height="300"
                IsVisible="{Binding IsLogViewerVisible}">
            <Grid RowDefinitions="Auto,Auto,*">
                <!-- Panel header -->
                <Border Grid.Row="0" Background="{DynamicResource LunaBgSecondary}" Padding="12,8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Developer Tools" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Button Classes="secondary" Command="{Binding ClearLogsCommand}" Padding="8,4">
                                <TextBlock Text="Clear Logs" FontSize="{DynamicResource LunaFontSizeSm}"/>
                            </Button>
                            <Button Classes="secondary" Command="{Binding ToggleLogViewerCommand}" Padding="8,4">
                                <TextBlock Text="X" FontSize="{DynamicResource LunaFontSizeSm}" FontWeight="Bold" Foreground="{DynamicResource LunaTextSecondary}"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Dev testing buttons -->
                <Border Grid.Row="1" Background="{DynamicResource LunaBgSecondary}" Padding="12,8"
                        BorderBrush="{DynamicResource LunaBorder}" BorderThickness="0,1,0,1">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Update Testing:" Foreground="{DynamicResource LunaTextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Button Classes="secondary" Command="{Binding DevShowUpdateBannerCommand}" Padding="10,6">
                            <TextBlock Text="Show Update Banner" FontSize="{DynamicResource LunaFontSizeXs}"/>
                        </Button>
                        <Button Classes="secondary" Command="{Binding DevSimulateDownloadCommand}" Padding="10,6">
                            <TextBlock Text="Simulate Download" FontSize="{DynamicResource LunaFontSizeXs}"/>
                        </Button>
                        <Button Classes="secondary" Command="{Binding DevResetUpdateStateCommand}" Padding="10,6">
                            <TextBlock Text="Reset State" FontSize="{DynamicResource LunaFontSizeXs}"/>
                        </Button>
                        <Border Width="1" Background="{DynamicResource LunaBorder}" Margin="8,0"/>
                        <Button Classes="secondary" Command="{Binding CheckForUpdatesCommand}" Padding="10,6">
                            <TextBlock Text="Check for Updates (Real)" FontSize="{DynamicResource LunaFontSizeXs}"/>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Log entries - TextBox allows multi-line selection and copy -->
                <TextBox Grid.Row="2"
                         Text="{Binding LogText}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         FontFamily="{DynamicResource LunaFontMono}"
                         FontSize="{DynamicResource LunaFontSizeXs}"
                         Foreground="{DynamicResource LunaTextSecondary}"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="8"
                         CaretBrush="{DynamicResource LunaCaret}"
                         SelectionBrush="{DynamicResource LunaSelection}"/>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="4"
                Background="{DynamicResource LunaBgSecondary}"
                BorderBrush="{DynamicResource LunaBorder}"
                BorderThickness="0,1,0,0" Padding="24,12">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource LunaTextSecondary}" VerticalAlignment="Center"/>

                <!-- Progress bar -->
                <ProgressBar Grid.Column="1"
                             Value="{Binding Progress}"
                             Maximum="100"
                             Width="200"
                             Height="4"
                             IsVisible="{Binding IsProcessing}"
                             Foreground="{DynamicResource LunaAccent}"
                             Background="{DynamicResource LunaBgTertiary}"/>
            </Grid>
        </Border>
    </Grid>

</Window>
