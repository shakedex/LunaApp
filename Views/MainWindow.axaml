<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LunaApp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:LunaApp.Models"
        xmlns:services="using:LunaApp.Services"
        xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="LunaApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/luna-logo.ico"
        Title="Luna"
        MinWidth="900"
        MinHeight="600"
        Background="#0d1117">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <!-- Custom styles for Luna's dark theme -->
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#e6edf3"/>
        </Style>
        
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#238636"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="#2ea043"/>
        </Style>
        <Style Selector="Button.primary:disabled">
            <Setter Property="Background" Value="#21262d"/>
            <Setter Property="Foreground" Value="#6e7681"/>
        </Style>
        
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#21262d"/>
            <Setter Property="Foreground" Value="#e6edf3"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.secondary:pointerover">
            <Setter Property="Background" Value="#30363d"/>
        </Style>
        
        <!-- Update button styling (white background, blue text) -->
        <Style Selector="Button.updateBtn">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.updateBtn:pointerover">
            <Setter Property="Background" Value="#dbeafe"/>
        </Style>
        <Style Selector="Button.updateBtn TextBlock">
            <Setter Property="Foreground" Value="#1f6feb"/>
        </Style>
        <Style Selector="Button.updateBtn:pointerover TextBlock">
            <Setter Property="Foreground" Value="#1f6feb"/>
        </Style>
        <Style Selector="Button.updateBtn mi|MaterialIcon">
            <Setter Property="Foreground" Value="#1f6feb"/>
        </Style>
        <Style Selector="Button.updateBtn:pointerover mi|MaterialIcon">
            <Setter Property="Foreground" Value="#1f6feb"/>
        </Style>
        
        <!-- Drop zone styling -->
        <Style Selector="Border.dropZone">
            <Setter Property="Background" Value="#161b22"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>
        <Style Selector="Border.dropZone:pointerover">
            <Setter Property="BorderBrush" Value="#58a6ff"/>
            <Setter Property="Background" Value="#0d1117"/>
        </Style>
        
        <!-- Card styling -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#161b22"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        
        <!-- Reel item styling -->
        <Style Selector="Border.reelItem">
            <Setter Property="Background" Value="#21262d"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        
        <!-- Clip item styling -->
        <Style Selector="Border.clipItem">
            <Setter Property="Background" Value="#161b22"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,0,0,1" Padding="24,16">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Logo and title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Image Source="/Assets/luna-logo.webp" Width="36" Height="36" RenderOptions.BitmapInterpolationMode="HighQuality"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Luna" FontSize="20" FontWeight="Bold" Foreground="#e6edf3"/>
                        <TextBlock Text="Camera Report Generator" FontSize="11" Foreground="#8b949e"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- Header buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <!-- DEV: Development tools toggle button -->
                    <Button Classes="secondary" Command="{Binding ToggleLogViewerCommand}" VerticalAlignment="Center" ToolTip.Tip="Toggle Developer Tools">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="Wrench" Width="16" Height="16" Foreground="#8b949e"/>
                            <TextBlock Text="Dev" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Settings button -->
                    <Button Classes="secondary" Command="{Binding OpenSettingsCommand}" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="Cog" Width="16" Height="16" Foreground="#8b949e"/>
                            <TextBlock Text="Settings" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Update banner - shows when update is available -->
        <Border Grid.Row="1" 
                Background="#1f6feb" 
                Padding="16,12"
                IsVisible="{Binding HasUpdateAvailable}">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Update icon and message -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <mi:MaterialIcon Kind="Update" Width="20" Height="20" Foreground="White"/>
                    <TextBlock Foreground="White" VerticalAlignment="Center">
                        <Run Text="Update available:"/>
                        <Run Text="{Binding UpdateVersion}" FontWeight="Bold"/>
                    </TextBlock>
                </StackPanel>
                
                <!-- Progress bar during download -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" 
                            IsVisible="{Binding IsDownloadingUpdate}" Margin="24,0">
                    <ProgressBar Value="{Binding UpdateDownloadProgress}" Maximum="100" 
                                 Width="200" Height="6" Foreground="White" Background="#3d7fe8"
                                 CornerRadius="3"/>
                    <TextBlock Text="{Binding UpdateDownloadProgress, StringFormat='{}{0}%'}" 
                               Foreground="White" FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- Action buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <!-- Download button (hidden when downloading or when update is ready) -->
                    <Button Classes="updateBtn" 
                            Command="{Binding DownloadUpdateCommand}" 
                            IsVisible="{Binding !IsUpdateReady}"
                            IsEnabled="{Binding !IsDownloadingUpdate}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Kind="Download" Width="14" Height="14"/>
                            <TextBlock Text="Download" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Restart button (shown after download) -->
                    <Button Command="{Binding ApplyUpdateCommand}" 
                            IsVisible="{Binding IsUpdateReady}"
                            Background="#238636" Foreground="White" Padding="12,6"
                            CornerRadius="4">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Kind="Restart" Width="14" Height="14" Foreground="White"/>
                            <TextBlock Text="Restart Now" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Dismiss button -->
                    <Button Command="{Binding DismissUpdateCommand}" 
                            Background="Transparent" Foreground="White" Padding="8,6"
                            ToolTip.Tip="Remind me later">
                        <TextBlock Text="X" FontWeight="Bold"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Main content -->
        <Grid Grid.Row="2" Margin="24">
            
            <!-- Empty state: Drop zone (only when no folder selected and not processing) -->
            <Border Classes="dropZone" 
                    IsVisible="{Binding ShowDropZone}"
                    DragDrop.AllowDrop="True"
                    Cursor="Hand">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                    <!-- Moon icon -->
                    <Border Width="80" Height="80" CornerRadius="40" Background="#21262d" HorizontalAlignment="Center">
                        <mi:MaterialIcon Kind="MoonWaningCrescent" Width="40" Height="40" Foreground="#58a6ff"/>
                    </Border>
                    <TextBlock Text="Drop camera footage here" FontSize="20" FontWeight="SemiBold" Foreground="#e6edf3" HorizontalAlignment="Center"/>
                    <TextBlock Text="or click to browse for a folder" FontSize="14" Foreground="#8b949e" HorizontalAlignment="Center"/>
                    <Button Classes="secondary" Command="{Binding BrowseFolderCommand}" HorizontalAlignment="Center" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="FolderOpen" Width="16" Height="16" Foreground="#8b949e"/>
                            <TextBlock Text="Browse Folder" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
            
            <!-- Pending confirmation state: Folder selected, waiting for user to start processing -->
            <Border Classes="dropZone" 
                    IsVisible="{Binding ShowPendingConfirmation}"
                    Background="#161b22">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">
                    <!-- Folder icon with checkmark -->
                    <Border Width="100" Height="100" CornerRadius="50" Background="#21262d" HorizontalAlignment="Center">
                        <mi:MaterialIcon Kind="FolderOpen" Width="48" Height="48" Foreground="#58a6ff"/>
                    </Border>
                    
                    <!-- Folder name and clip count -->
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding PendingFolderName}" FontSize="22" FontWeight="Bold" Foreground="#e6edf3" HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                            <TextBlock FontSize="48" FontWeight="Bold" Foreground="#58a6ff" VerticalAlignment="Center">
                                <TextBlock.Text>
                                    <Binding Path="PendingClipCount"/>
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock Text="video clips found" FontSize="18" Foreground="#8b949e" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
                        <Button Classes="secondary" Command="{Binding CancelPendingCommand}" Padding="24,14">
                            <TextBlock Text="Cancel" FontSize="14"/>
                        </Button>
                        <Button Classes="primary" Command="{Binding StartProcessingCommand}" Padding="32,14">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <mi:MaterialIcon Kind="CheckCircle" Width="20" Height="20" Foreground="White"/>
                                <TextBlock Text="Create Report" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    
                    <!-- Hint text -->
                    <TextBlock Text="Clicking 'Create Report' will extract metadata and thumbnails from your footage" 
                               FontSize="13" Foreground="#6e7681" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <!-- Content: Reels list -->
            <Grid IsVisible="{Binding HasReels}" ColumnDefinitions="*,320">
                
                <!-- Reels and clips -->
                <ScrollViewer Grid.Column="0" Margin="0,0,16,0">
                    <ItemsControl ItemsSource="{Binding Reels}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:CameraReel">
                                <Border Classes="reelItem" Margin="0,0,0,16">
                                    <StackPanel Spacing="12">
                                        <!-- Reel header -->
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0" Background="#58a6ff" CornerRadius="4" Padding="12,6" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayLabel}" FontWeight="Bold" Foreground="#0d1117"/>
                                            </Border>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                                                <TextBlock Foreground="#8b949e">
                                                    <Run Text="{Binding ClipCount}"/>
                                                    <Run Text="clips"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding TotalDuration, StringFormat='{}{0:hh\\:mm\\:ss}'}" Foreground="#8b949e"/>
                                            </StackPanel>
                                        </Grid>
                                        
                                        <!-- Clips list -->
                                        <ItemsControl ItemsSource="{Binding Clips}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="models:CameraClip">
                                                    <Border Classes="clipItem">
                                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                                            <!-- Single thumbnail or video icon -->
                                                            <Grid Grid.Column="0" Width="80" Height="45" Margin="0,0,16,0">
                                                                <!-- Actual thumbnail image -->
                                                                <Image Source="{Binding FirstThumbnail.Bitmap}"
                                                                       Width="80" Height="45"
                                                                       Stretch="UniformToFill"
                                                                       IsVisible="{Binding HasThumbnail}"/>
                                                                <!-- Fallback: Video icon when no thumbnail -->
                                                                <Border Width="80" Height="45" Background="#30363d" CornerRadius="2"
                                                                        IsVisible="{Binding !HasThumbnail}">
                                                                    <mi:MaterialIcon Kind="Video" Width="24" Height="24" Foreground="#6e7681"/>
                                                                </Border>
                                                            </Grid>
                                                            
                                                            <!-- Clip info -->
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                                                <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" Foreground="#e6edf3"/>
                                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                                    <TextBlock Text="{Binding Resolution}" FontSize="12" Foreground="#8b949e"/>
                                                                    <TextBlock Text="{Binding Codec}" FontSize="12" Foreground="#8b949e"/>
                                                                    <TextBlock Text="{Binding DurationFormatted}" FontSize="12" Foreground="#8b949e"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                            
                                                            <!-- Timecode -->
                                                            <TextBlock Grid.Column="2" Text="{Binding Timecode}" 
                                                                       FontFamily="Consolas" FontSize="12" 
                                                                       Foreground="#58a6ff" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                
                <!-- Sidebar: Summary and actions -->
                <Border Grid.Column="1" Classes="card" Padding="20">
                    <StackPanel Spacing="20">
                        <TextBlock Text="Report Summary" FontSize="16" FontWeight="SemiBold"/>
                        
                        <!-- Stats -->
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Reels" Foreground="#8b949e"/>
                                <TextBlock Grid.Column="1" Text="{Binding ReelCount}" FontWeight="SemiBold"/>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Total Clips" Foreground="#8b949e"/>
                                <TextBlock Grid.Column="1" Text="{Binding TotalClipCount}" FontWeight="SemiBold"/>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Total Duration" Foreground="#8b949e"/>
                                <TextBlock Grid.Column="1" Text="{Binding TotalDuration, StringFormat='{}{0:hh\\:mm\\:ss}'}" FontWeight="SemiBold"/>
                            </Grid>
                        </StackPanel>
                        
                        <Border Height="1" Background="#30363d"/>
                        
                        <!-- Output options -->
                        <StackPanel Spacing="8">
                            <CheckBox Content="HTML Report" IsChecked="{Binding GenerateHtml}" Foreground="#e6edf3"/>
                            <CheckBox Content="PDF Report" IsChecked="{Binding GeneratePdf}" Foreground="#e6edf3"/>
                            <CheckBox Content="Open when complete" IsChecked="{Binding OpenWhenDone}" Foreground="#8b949e" FontSize="12"/>
                        </StackPanel>
                        
                        <Border Height="1" Background="#30363d"/>
                        
                        <!-- Generate button -->
                        <Button Classes="primary" 
                                Command="{Binding GenerateReportsCommand}" 
                                IsEnabled="{Binding CanGenerate}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <mi:MaterialIcon Kind="CheckCircle" Width="18" Height="18" Foreground="White"
                                          IsVisible="{Binding !IsProcessing}"/>
                                <TextBlock Text="{Binding GenerateButtonText}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        
                        <!-- Clear button -->
                        <Button Classes="secondary" 
                                Command="{Binding ClearCommand}" 
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                IsVisible="{Binding HasReels}">
                            <TextBlock Text="Clear &amp; Start Over"/>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
            
            <!-- Processing overlay - shows on top when processing -->
            <Border IsVisible="{Binding IsProcessing}"
                    Background="#0d1117"
                    CornerRadius="12"
                    IsHitTestVisible="True">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">
                    <!-- Moon icon with pulsing effect -->
                    <Grid Width="120" Height="120" HorizontalAlignment="Center">
                        <Border Width="120" Height="120" CornerRadius="60" BorderBrush="#21262d" BorderThickness="4"/>
                        <Border Width="80" Height="80" CornerRadius="40" Background="#161b22" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <mi:MaterialIcon Kind="MoonWaningCrescent" Width="40" Height="40" Foreground="#58a6ff"/>
                        </Border>
                    </Grid>
                    
                    <!-- Status text -->
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding StatusText}" FontSize="18" FontWeight="SemiBold" Foreground="#e6edf3" HorizontalAlignment="Center" TextAlignment="Center"/>
                        <TextBlock Text="Processing your footage..." FontSize="14" Foreground="#8b949e" HorizontalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Progress bar -->
                    <StackPanel Spacing="8" Width="400" HorizontalAlignment="Center">
                        <ProgressBar Value="{Binding Progress}" 
                                     Maximum="100"
                                     Height="8"
                                     Foreground="#58a6ff"
                                     Background="#21262d"
                                     CornerRadius="4"/>
                        <TextBlock Text="{Binding Progress, StringFormat='{}{0}%'}" 
                                   FontSize="14" 
                                   Foreground="#8b949e" 
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- DEV: Developer Tools panel -->
        <Border Grid.Row="3" 
                Background="#0d1117" 
                BorderBrush="#30363d" 
                BorderThickness="0,1,0,0"
                Height="300"
                IsVisible="{Binding IsLogViewerVisible}">
            <Grid RowDefinitions="Auto,Auto,*">
                <!-- Panel header -->
                <Border Grid.Row="0" Background="#161b22" Padding="12,8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Developer Tools" FontWeight="SemiBold" Foreground="#e6edf3" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Button Classes="secondary" Command="{Binding ClearLogsCommand}" Padding="8,4">
                                <TextBlock Text="Clear Logs" FontSize="12"/>
                            </Button>
                            <Button Classes="secondary" Command="{Binding ToggleLogViewerCommand}" Padding="8,4">
                                <TextBlock Text="X" FontSize="12" FontWeight="Bold" Foreground="#8b949e"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- Dev testing buttons -->
                <Border Grid.Row="1" Background="#161b22" Padding="12,8" BorderBrush="#30363d" BorderThickness="0,1,0,1">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Update Testing:" Foreground="#8b949e" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Button Classes="secondary" Command="{Binding DevShowUpdateBannerCommand}" Padding="10,6">
                            <TextBlock Text="Show Update Banner" FontSize="11"/>
                        </Button>
                        <Button Classes="secondary" Command="{Binding DevSimulateDownloadCommand}" Padding="10,6">
                            <TextBlock Text="Simulate Download" FontSize="11"/>
                        </Button>
                        <Button Classes="secondary" Command="{Binding DevResetUpdateStateCommand}" Padding="10,6">
                            <TextBlock Text="Reset State" FontSize="11"/>
                        </Button>
                        <Border Width="1" Background="#30363d" Margin="8,0"/>
                        <Button Classes="secondary" Command="{Binding CheckForUpdatesCommand}" Padding="10,6">
                            <TextBlock Text="Check for Updates (Real)" FontSize="11"/>
                        </Button>
                    </StackPanel>
                </Border>
                
                <!-- Log entries - TextBox allows multi-line selection and copy -->
                <TextBox Grid.Row="2" 
                         Text="{Binding LogText}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         FontFamily="Consolas, Courier New, monospace"
                         FontSize="11"
                         Foreground="#8b949e"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="8"
                         CaretBrush="#58a6ff"
                         SelectionBrush="#264f78"/>
            </Grid>
        </Border>
        
        <!-- Status bar -->
        <Border Grid.Row="4" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,1,0,0" Padding="24,12">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{Binding StatusText}" Foreground="#8b949e" VerticalAlignment="Center"/>
                
                <!-- Progress bar -->
                <ProgressBar Grid.Column="1" 
                             Value="{Binding Progress}" 
                             Maximum="100"
                             Width="200"
                             Height="4"
                             IsVisible="{Binding IsProcessing}"
                             Foreground="#58a6ff"
                             Background="#21262d"/>
            </Grid>
        </Border>
    </Grid>

</Window>
